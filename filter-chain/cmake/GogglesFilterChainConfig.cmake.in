@PACKAGE_INIT@

include("${CMAKE_CURRENT_LIST_DIR}/FilterChainDependencies.cmake")

include("${CMAKE_CURRENT_LIST_DIR}/GogglesFilterChainTargets.cmake")

# Built-in runtime assets are now embedded in the library binary.
# No public asset-directory path is exported or required.

if(@FILTER_CHAIN_LIBRARY_TYPE_IS_STATIC@)
    set(_goggles_filter_chain_cxx_runtime_libraries
        "@FILTER_CHAIN_CXX_IMPLICIT_LINK_LIBRARIES@")
    set(_goggles_filter_chain_cxx_runtime_directories
        "@FILTER_CHAIN_CXX_IMPLICIT_LINK_DIRECTORIES@")

    find_library(GOGGLES_FILTER_CHAIN_PRIVATE_SPDLOG_LIBRARY
        NAMES spdlog libspdlog
        HINTS "$ENV{CONDA_PREFIX}/lib")
    if(NOT GOGGLES_FILTER_CHAIN_PRIVATE_SPDLOG_LIBRARY)
        message(FATAL_ERROR
            "GogglesFilterChain static package requires the spdlog shared library at link time.")
    endif()

    find_library(GOGGLES_FILTER_CHAIN_PRIVATE_FMT_LIBRARY
        NAMES fmt libfmt
        HINTS "$ENV{CONDA_PREFIX}/lib")
    if(NOT GOGGLES_FILTER_CHAIN_PRIVATE_FMT_LIBRARY)
        message(FATAL_ERROR
            "GogglesFilterChain static package requires the fmt shared library at link time.")
    endif()

    find_package(Threads REQUIRED)

    find_library(GOGGLES_FILTER_CHAIN_PRIVATE_SLANG_LIBRARY
        NAMES slang-compiler slang libslang-compiler libslang
        HINTS "$ENV{CONDA_PREFIX}/lib")
    if(NOT GOGGLES_FILTER_CHAIN_PRIVATE_SLANG_LIBRARY)
        message(FATAL_ERROR
            "GogglesFilterChain static package requires the slang shared library at link time.")
    endif()

    get_target_property(_goggles_filter_chain_link_libraries
        GogglesFilterChain::goggles-filter-chain
        INTERFACE_LINK_LIBRARIES)
    string(REPLACE "$<LINK_ONLY:spdlog::spdlog>"
        "$<LINK_ONLY:${GOGGLES_FILTER_CHAIN_PRIVATE_SPDLOG_LIBRARY}>;$<LINK_ONLY:${GOGGLES_FILTER_CHAIN_PRIVATE_FMT_LIBRARY}>;Threads::Threads"
        _goggles_filter_chain_link_libraries
        "${_goggles_filter_chain_link_libraries}")
    string(REPLACE "$<LINK_ONLY:slang::slang>"
        "$<LINK_ONLY:${GOGGLES_FILTER_CHAIN_PRIVATE_SLANG_LIBRARY}>"
        _goggles_filter_chain_link_libraries
        "${_goggles_filter_chain_link_libraries}")

    foreach(_goggles_filter_chain_runtime_library IN LISTS _goggles_filter_chain_cxx_runtime_libraries)
        if(NOT _goggles_filter_chain_runtime_library STREQUAL "")
            list(APPEND _goggles_filter_chain_link_libraries
                "$<LINK_ONLY:${_goggles_filter_chain_runtime_library}>")
        endif()
    endforeach()
    list(REMOVE_DUPLICATES _goggles_filter_chain_link_libraries)

    get_target_property(_goggles_filter_chain_link_directories
        GogglesFilterChain::goggles-filter-chain
        INTERFACE_LINK_DIRECTORIES)
    if(_goggles_filter_chain_link_directories STREQUAL
       "_goggles_filter_chain_link_directories-NOTFOUND")
        set(_goggles_filter_chain_link_directories "")
    endif()
    list(APPEND _goggles_filter_chain_link_directories
        ${_goggles_filter_chain_cxx_runtime_directories})
    list(REMOVE_DUPLICATES _goggles_filter_chain_link_directories)

    set_target_properties(GogglesFilterChain::goggles-filter-chain PROPERTIES
        INTERFACE_LINK_LIBRARIES "${_goggles_filter_chain_link_libraries}"
        INTERFACE_LINK_DIRECTORIES "${_goggles_filter_chain_link_directories}")
    unset(_goggles_filter_chain_cxx_runtime_libraries)
    unset(_goggles_filter_chain_cxx_runtime_directories)
    unset(_goggles_filter_chain_link_directories)
    unset(_goggles_filter_chain_runtime_library)
    unset(_goggles_filter_chain_link_libraries)
endif()

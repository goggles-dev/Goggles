{
  "version": 5,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": ".common",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": ".debug",
      "hidden": true,
      "inherits": ".common",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": ".release",
      "hidden": true,
      "inherits": ".common",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": ".relwithdebinfo",
      "hidden": true,
      "inherits": ".common",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": ".asan",
      "hidden": true,
      "cacheVariables": {
        "ENABLE_ASAN": "ON"
      }
    },
    {
      "name": ".ubsan",
      "hidden": true,
      "cacheVariables": {
        "ENABLE_UBSAN": "ON"
      }
    },
    {
      "name": ".test",
      "hidden": true,
      "cacheVariables": {
        "BUILD_TESTING": "ON",
        "CMAKE_BUILD_PARALLEL_LEVEL": "4"
      }
    },
    {
      "name": ".clang-tidy",
      "hidden": true,
      "cacheVariables": {
        "ENABLE_CLANG_TIDY": "ON"
      }
    },
    {
      "name": ".profiling",
      "hidden": true,
      "cacheVariables": {
        "ENABLE_PROFILING": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "description": "Debug build with no optimizations",
      "inherits": ".debug"
    },
    {
      "name": "release",
      "displayName": "Release",
      "description": "Release build with optimizations",
      "inherits": ".release"
    },
    {
      "name": "relwithdebinfo",
      "displayName": "RelWithDebInfo",
      "description": "Release with debug symbols for profiling",
      "inherits": ".relwithdebinfo"
    },
    {
      "name": "asan",
      "displayName": "Debug + AddressSanitizer",
      "description": "Debug build with AddressSanitizer for memory issues",
      "inherits": [
        ".debug",
        ".asan"
      ]
    },
    {
      "name": "ubsan",
      "displayName": "Debug + UndefinedBehaviorSanitizer",
      "description": "Debug build with UBSan for undefined behavior",
      "inherits": [
        ".debug",
        ".ubsan"
      ]
    },
    {
      "name": "asan-ubsan",
      "displayName": "Debug + ASAN + UBSAN",
      "description": "Debug build with both sanitizers",
      "inherits": [
        ".debug",
        ".asan",
        ".ubsan"
      ]
    },
    {
      "name": "test",
      "displayName": "Test (Debug + ASAN + Clang-Tidy)",
      "description": "Optimized for testing with AddressSanitizer, parallel builds, and static analysis",
      "inherits": [
        ".debug",
        ".asan",
        ".test",
        ".clang-tidy"
      ]
    },
    {
      "name": "quality",
      "displayName": "Quality Assurance (Debug + ASAN + Clang-Tidy)",
      "description": "Debug build with comprehensive code quality checks",
      "inherits": [
        ".debug",
        ".asan",
        ".clang-tidy"
      ]
    },
    {
      "name": "profile",
      "displayName": "Profile (Release + Tracy)",
      "description": "Release build with Tracy profiler enabled",
      "inherits": [
        ".release",
        ".profiling"
      ]
    },
    {
      "name": "smoke-static-clang",
      "displayName": "Smoke static (clang)",
      "description": "Local smoke lane: static filter-chain with clang",
      "inherits": [
        ".debug"
      ],
      "cacheVariables": {
        "GOGGLES_CHAIN_LIBRARY_TYPE": "STATIC",
        "CMAKE_C_COMPILER": "$env{CC}",
        "CMAKE_CXX_COMPILER": "$env{CXX}"
      }
    },
    {
      "name": "smoke-shared-clang",
      "displayName": "Smoke shared (clang)",
      "description": "Local smoke lane: shared filter-chain with clang",
      "inherits": [
        ".debug"
      ],
      "cacheVariables": {
        "GOGGLES_CHAIN_LIBRARY_TYPE": "SHARED",
        "CMAKE_C_COMPILER": "$env{CC}",
        "CMAKE_CXX_COMPILER": "$env{CXX}"
      }
    },
    {
      "name": "smoke-static-gcc",
      "displayName": "Smoke static (gcc)",
      "description": "Local smoke lane: static filter-chain with gcc",
      "inherits": [
        ".debug"
      ],
      "cacheVariables": {
        "GOGGLES_CHAIN_LIBRARY_TYPE": "STATIC",
        "CMAKE_C_COMPILER": "$env{GCC}",
        "CMAKE_CXX_COMPILER": "$env{GXX}"
      }
    },
    {
      "name": "smoke-shared-gcc",
      "displayName": "Smoke shared (gcc)",
      "description": "Local smoke lane: shared filter-chain with gcc",
      "inherits": [
        ".debug"
      ],
      "cacheVariables": {
        "GOGGLES_CHAIN_LIBRARY_TYPE": "SHARED",
        "CMAKE_C_COMPILER": "$env{GCC}",
        "CMAKE_CXX_COMPILER": "$env{GXX}"
      }
    },
    {
      "name": "smoke-provider-in-tree",
      "displayName": "Provider rehearsal (in-tree)",
      "description": "Smoke rehearsal of in-tree filter-chain provider consumption",
      "inherits": [
        ".debug",
        ".test"
      ],
      "cacheVariables": {
        "GOGGLES_FILTER_CHAIN_PROVIDER": "in-tree"
      }
    },
    {
      "name": "smoke-provider-package-stage",
      "displayName": "Provider rehearsal package stage",
      "description": "Build and install the filter-chain package for provider rehearsal",
      "inherits": [
        ".debug",
        ".test"
      ],
      "cacheVariables": {
        "GOGGLES_FILTER_CHAIN_PROVIDER": "in-tree",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/smoke-provider-package-root"
      }
    },
    {
      "name": "smoke-provider-package-consumer",
      "displayName": "Provider rehearsal (package consumer)",
      "description": "Consume goggles-filter-chain through the installed package bridge",
      "inherits": [
        ".debug",
        ".test"
      ],
      "cacheVariables": {
        "GOGGLES_FILTER_CHAIN_PROVIDER": "package",
        "GOGGLES_FILTER_CHAIN_PACKAGE": "goggles-filter-chain",
        "CMAKE_PREFIX_PATH": "${sourceDir}/build/smoke-provider-package-root"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "relwithdebinfo",
      "configurePreset": "relwithdebinfo"
    },
    {
      "name": "asan",
      "configurePreset": "asan"
    },
    {
      "name": "ubsan",
      "configurePreset": "ubsan"
    },
    {
      "name": "asan-ubsan",
      "configurePreset": "asan-ubsan"
    },
    {
      "name": "test",
      "configurePreset": "test"
    },
    {
      "name": "quality",
      "configurePreset": "quality"
    },
    {
      "name": "profile",
      "configurePreset": "profile"
    },
    {
      "name": "smoke-static-clang",
      "configurePreset": "smoke-static-clang"
    },
    {
      "name": "smoke-shared-clang",
      "configurePreset": "smoke-shared-clang"
    },
    {
      "name": "smoke-static-gcc",
      "configurePreset": "smoke-static-gcc"
    },
    {
      "name": "smoke-shared-gcc",
      "configurePreset": "smoke-shared-gcc"
    },
    {
      "name": "smoke-provider-in-tree",
      "configurePreset": "smoke-provider-in-tree"
    },
    {
      "name": "smoke-provider-package-stage",
      "configurePreset": "smoke-provider-package-stage"
    },
    {
      "name": "smoke-provider-package-consumer",
      "configurePreset": "smoke-provider-package-consumer"
    }
  ],
  "testPresets": [
    {
      "name": "test",
      "displayName": "Test Execution (with parallel execution)",
      "description": "Optimized test execution with AddressSanitizer",
      "configurePreset": "test",
      "output": {
        "verbosity": "verbose"
      },
      "execution": {
        "jobs": 0
      }
    },
    {
      "name": "asan",
      "displayName": "ASAN Test Execution",
      "description": "Test execution with AddressSanitizer",
      "configurePreset": "asan",
      "output": {
        "verbosity": "verbose"
      },
      "execution": {
        "jobs": 0
      }
    },
    {
      "name": "smoke-provider-in-tree",
      "displayName": "Provider rehearsal test execution (in-tree)",
      "description": "Run contract and host tests against the in-tree provider path",
      "configurePreset": "smoke-provider-in-tree",
      "output": {
        "verbosity": "verbose"
      },
      "execution": {
        "jobs": 0
      }
    },
    {
      "name": "smoke-provider-package-consumer",
      "displayName": "Provider rehearsal test execution (package)",
      "description": "Run contract and host tests against the package provider path",
      "configurePreset": "smoke-provider-package-consumer",
      "output": {
        "verbosity": "verbose"
      },
      "execution": {
        "jobs": 0
      }
    }
  ]
}
